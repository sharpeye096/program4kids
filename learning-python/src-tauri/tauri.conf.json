{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "AI-Efficiency-Presentation",
  "version": "0.1.0",
  "identifier": "com.ai-efficiency.presentation",
  "build": {
    "frontendDist": "../public/ai-efficiency",
    "devUrl": "http://localhost:8000/ai-efficiency",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "AI提效：业务人员的进化",
        "width": 1440,
        "height": 900,
        "resizable": true,
        "fullscreen": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}